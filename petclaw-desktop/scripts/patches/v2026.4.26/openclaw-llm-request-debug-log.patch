index 0000000000..1a58edf248
--- /dev/null
+++ b/src/agents/request-debug-logger.ts
@@ -0,0 +1,213 @@
+import type { StreamFn } from "@mariozechner/pi-agent-core";
+import type { Api, AssistantMessageEvent, Model } from "@mariozechner/pi-ai";
+// @ts-ignore -- 子路径未在 exports map 中声明，但运行时存在
+import type { AssistantMessageEventStream } from "@mariozechner/pi-ai/dist/utils/event-stream.js";
+import { createSubsystemLogger } from "../logging/subsystem.js";
+import { parseBooleanValue } from "../utils/boolean.js";
+import { safeJsonStringify } from "../utils/safe-json.js";
+
+const log = createSubsystemLogger("agent/request-debug");
+
+let requestCounter = 0;
+
+function isEnabled(env: NodeJS.ProcessEnv): boolean {
+  return parseBooleanValue(env.OPENCLAW_LLM_REQUEST_DEBUG_LOG) ?? false;
+}
+
+function truncate(s: string, max: number): string {
+  return s.length <= max ? s : `${s.slice(0, max)}...(truncated, total ${s.length} chars)`;
+}
+
+function safeSerialize(value: unknown, maxChars = 8000): string {
+  const raw = safeJsonStringify(value) ?? String(value);
+  return truncate(raw, maxChars);
+}
+
+type OriginalFetch = typeof globalThis.fetch;
+
+const LLM_URL_PATTERNS = [
+  "api.anthropic.com",
+  "api.openai.com",
+  "generativelanguage.googleapis.com",
+  "aiplatform.googleapis.com",
+  "bedrock-runtime",
+  "/api/chat",
+  "/v1/chat",
+  "/v1/messages",
+  "/v1/responses",
+  "/v1beta/models",
+];
+
+function isLlmRelatedUrl(url: string): boolean {
+  return LLM_URL_PATTERNS.some((p) => url.includes(p));
+}
+
+function headersToRecord(headers: HeadersInit | undefined): Record<string, string> {
+  const result: Record<string, string> = {};
+  if (!headers) return result;
+  if (headers instanceof Headers) {
+    headers.forEach((value, key) => { result[key] = value; });
+    return result;
+  }
+  if (Array.isArray(headers)) {
+    for (const [key, value] of headers) {
+      result[key] = value;
+    }
+    return result;
+  }
+  return { ...(headers as Record<string, string>) };
+}
+
+function installFetchInterceptor(): () => void {
+  const originalFetch: OriginalFetch = globalThis.fetch;
+
+  const interceptedFetch: typeof globalThis.fetch = async (input, init) => {
+    const url =
+      typeof input === "string"
+        ? input
+        : input instanceof URL
+          ? input.toString()
+          : input instanceof Request
+            ? input.url
+            : String(input);
+
+    if (!isLlmRelatedUrl(url)) {
+      return originalFetch(input, init);
+    }
+
+    const reqId = ++requestCounter;
+    const requestHeaders = headersToRecord(
+      init?.headers ?? (input instanceof Request ? input.headers : undefined),
+    );
+    const method = init?.method ?? (input instanceof Request ? input.method : "GET");
+
+    log.info(
+      `[http-request] #${reqId} ${safeJsonStringify({ method, url, headers: requestHeaders }) ?? ""}`,
+    );
+
+    const startTime = Date.now();
+    let response: Response;
+    try {
+      response = await originalFetch(input, init);
+    } catch (err) {
+      log.info(
+        `[http-error] #${reqId} elapsed=${Date.now() - startTime}ms error=${err instanceof Error ? err.message : String(err)}`,
+      );
+      throw err;
+    }
+
+    const elapsed = Date.now() - startTime;
+    const responseHeaders: Record<string, string> = {};
+    response.headers.forEach((value, key) => { responseHeaders[key] = value; });
+
+    log.info(
+      `[http-response] #${reqId} ${safeJsonStringify({ status: response.status, statusText: response.statusText, elapsed: `${elapsed}ms`, headers: responseHeaders }) ?? ""}`,
+    );
+
+    return response;
+  };
+
+  globalThis.fetch = interceptedFetch;
+
+  return () => {
+    if (globalThis.fetch === interceptedFetch) {
+      globalThis.fetch = originalFetch;
+    }
+  };
+}
+
+function wrapEventStream(
+  stream: AssistantMessageEventStream,
+  reqId: number,
+): AssistantMessageEventStream {
+  const originalIterator = stream[Symbol.asyncIterator].bind(stream);
+
+  const wrappedIterator = (): AsyncIterator<AssistantMessageEvent> => {
+    const iter = originalIterator();
+    return {
+      next: async () => {
+        const result = await iter.next();
+        if (!result.done && result.value) {
+          const event = result.value;
+          if (event.type === "done" || event.type === "error") {
+            const msg = "message" in event
+              ? (event as { message?: { content?: unknown; stopReason?: string; usage?: unknown; errorMessage?: string } }).message
+              : ("error" in event ? (event as { error?: { content?: unknown; stopReason?: string; usage?: unknown; errorMessage?: string } }).error : undefined);
+            log.info(`[llm-response] #${reqId} ${safeJsonStringify({
+              reqId,
+              eventType: event.type,
+              stopReason: msg?.stopReason ?? ("reason" in event ? (event as { reason?: string }).reason : undefined),
+              content: safeSerialize(msg?.content, 4000),
+              usage: msg?.usage,
+              errorMessage: msg?.errorMessage,
+            }) ?? ""}`);
+          }
+        }
+        return result;
+      },
+      return: iter.return?.bind(iter),
+      throw: iter.throw?.bind(iter),
+    };
+  };
+
+  (stream as unknown as { [Symbol.asyncIterator]: () => AsyncIterator<AssistantMessageEvent> })[Symbol.asyncIterator] = wrappedIterator;
+  return stream;
+}
+
+export type RequestDebugLogger = {
+  enabled: true;
+  wrapStreamFn: (streamFn: StreamFn) => StreamFn;
+  dispose: () => void;
+};
+
+export function createRequestDebugLogger(params?: {
+  env?: NodeJS.ProcessEnv;
+}): RequestDebugLogger | null {
+  const env = params?.env ?? process.env;
+  if (!isEnabled(env)) {
+    return null;
+  }
+
+  log.info("LLM request debug logger enabled (fetch interceptor + stream wrapper active)");
+
+  const removeFetchInterceptor = installFetchInterceptor();
+
+  const wrapStreamFn: RequestDebugLogger["wrapStreamFn"] = (streamFn) => {
+    const wrapped: StreamFn = (model, context, options) => {
+      const reqId = ++requestCounter;
+      const modelRef = model as Model<Api> | undefined;
+
+      const nextOnPayload = (payload: unknown) => {
+        log.info(`[llm-request-body] #${reqId} ${safeJsonStringify({
+          reqId,
+          baseUrl: modelRef?.baseUrl ?? "(unknown)",
+          modelId: modelRef?.id,
+          api: (modelRef as { api?: string })?.api,
+          provider: (modelRef as { provider?: string })?.provider,
+          body: safeSerialize(payload),
+        }) ?? ""}`);
+        options?.onPayload?.(payload, model);
+      };
+
+      const result = streamFn(model, context, { ...options, onPayload: nextOnPayload });
+
+      if (result && typeof (result as Promise<AssistantMessageEventStream>).then === "function") {
+        return (result as Promise<AssistantMessageEventStream>).then((stream) =>
+          wrapEventStream(stream, reqId),
+        ) as ReturnType<StreamFn>;
+      }
+
+      return wrapEventStream(result as AssistantMessageEventStream, reqId);
+    };
+    return wrapped;
+  };
+
+  return {
+    enabled: true,
+    wrapStreamFn,
+    dispose: () => {
+      removeFetchInterceptor();
+      log.info("LLM request debug logger disposed");
+    },
+  };
+}
