diff --git a/src/agents/pi-embedded-runner/deepseek-stream-wrappers.ts b/src/agents/pi-embedded-runner/deepseek-stream-wrappers.ts
new file mode 100644
index 0000000000..6c42eb4937
--- /dev/null
+++ b/src/agents/pi-embedded-runner/deepseek-stream-wrappers.ts
@@ -0,0 +1,74 @@
+import type { StreamFn } from "@mariozechner/pi-agent-core";
+import { streamSimple } from "@mariozechner/pi-ai";
+import type { ThinkLevel } from "../../auto-reply/thinking.js";
+
+type DeepSeekThinkingType = "enabled" | "disabled";
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return !!value && typeof value === "object" && !Array.isArray(value);
+}
+
+function isDeepSeekV4ModelId(modelId: unknown): boolean {
+  return typeof modelId === "string" && /^deepseek-v4(?:[-_.]|$)/i.test(modelId.trim());
+}
+
+function resolveDeepSeekThinkingType(thinkingLevel?: ThinkLevel): DeepSeekThinkingType | undefined {
+  if (!thinkingLevel) {
+    return undefined;
+  }
+  return thinkingLevel === "off" ? "disabled" : "enabled";
+}
+
+function isDeepSeekV4Model(model: {
+  provider?: unknown;
+  id?: unknown;
+}): boolean {
+  return (
+    model.provider === "deepseek" &&
+    isDeepSeekV4ModelId(model.id)
+  );
+}
+
+/**
+ * DeepSeek V4 defaults to thinking mode. In tool-use turns, DeepSeek requires
+ * the previous assistant `reasoning_content` to be replayed. OpenClaw's default
+ * think level is `off`, so make that intent explicit for DeepSeek V4 instead of
+ * letting the provider enter thinking mode implicitly and then reject tool
+ * continuations that do not carry reasoning_content.
+ */
+export function createDeepSeekThinkingModeWrapper(
+  baseStreamFn: StreamFn | undefined,
+  thinkingLevel?: ThinkLevel,
+): StreamFn {
+  const underlying = baseStreamFn ?? streamSimple;
+  const thinkingType = resolveDeepSeekThinkingType(thinkingLevel);
+
+  return (model, context, options) => {
+    if (!thinkingType || !isDeepSeekV4Model(model)) {
+      return underlying(model, context, options);
+    }
+
+    const originalOnPayload = options?.onPayload;
+    return underlying(model, context, {
+      ...options,
+      onPayload: (payload) => {
+        if (isRecord(payload)) {
+          const hasExplicitThinking = Object.hasOwn(payload, "thinking");
+          if (!hasExplicitThinking || payload.thinking === undefined) {
+            payload.thinking = { type: thinkingType };
+          }
+
+          if (payload.thinking && isRecord(payload.thinking)) {
+            const type = payload.thinking.type;
+            if (type === "disabled") {
+              delete payload.reasoning;
+              delete payload.reasoning_effort;
+              delete payload.reasoningEffort;
+            }
+          }
+        }
+        return originalOnPayload?.(payload, model);
+      },
+    });
+  };
+}
