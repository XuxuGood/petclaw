{
  "name": "petclaw",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "ai:bootstrap": "node scripts/ai/bootstrap-tools.cjs",
    "ai:doctor": "node scripts/ai/doctor-ai-context.cjs",
    "ai:index": "node scripts/ai/gitnexus-refresh.cjs",
    "ai:impact": "node scripts/ai/gitnexus-impact.cjs",
    "ai:mcp:guide": "node scripts/ai/guide-mcp-config.cjs",
    "ai:mcp:install": "node scripts/ai/install-mcp-config.cjs",
    "ai:mcp:write": "node scripts/ai/write-mcp-config.cjs",
    "ai:prepare-change": "node scripts/ai/prepare-change.cjs",
    "ai:serena:dashboard": "node scripts/ai/serena-dashboard.cjs",
    "ai:setup": "node scripts/ai/setup-ai-context.cjs",
    "ai:tools:check": "node scripts/ai/check-ai-tools.cjs",
    "dev:desktop": "pnpm --filter petclaw-desktop dev",
    "build:desktop": "pnpm --filter petclaw-desktop build",
    "test": "pnpm -r test",
    "test:desktop": "pnpm --filter petclaw-desktop test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "petclaw-desktop/**/*.{ts,tsx}": [
      "pnpm --filter petclaw-desktop exec prettier --write",
      "pnpm --filter petclaw-desktop exec eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
